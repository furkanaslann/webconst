---

<BaseLayout
  title="Referanslar - Webconst"
  description="Webconst'in tamamladığı projeleri ve müşteri referanslarını inceleyin. 500+ başarılı proje ile yapı sektöründe güvenilir çözüm ortağınız."
>
  <Section bgColor="gray">
    <div class="py-20 px-10">
      <div class="max-w-4xl mx-auto text-center mb-16 animate-on-scroll">
        <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">
          Referans Projelerimiz
        </h1>
        <p class="text-xl text-gray-600">
          20+ yıllık tecrübemizle 500'ü aşkın projeyi başarıyla tamamladık
        </p>
      </div>

      <div class="mb-12 filter-container animate-on-scroll" style="transition-delay: 100ms">
        <div class="flex flex-wrap gap-3 justify-center">
          <button class="filter-btn active px-4 py-2 rounded-lg bg-accent-500 text-white font-medium transition-all duration-300 hover:scale-105" data-filter="all">
            Tümü
          </button>
          <button class="filter-btn px-4 py-2 rounded-lg bg-white text-gray-700 font-medium hover:bg-accent-100 transition-all duration-300 hover:scale-105" data-filter="guclendirme">
            Güçlendirme
          </button>
          <button class="filter-btn px-4 py-2 rounded-lg bg-white text-gray-700 font-medium hover:bg-accent-100 transition-all duration-300 hover:scale-105" data-filter="yalitim">
            Su Yalıtım
          </button>
          <button class="filter-btn px-4 py-2 rounded-lg bg-white text-gray-700 font-medium hover:bg-accent-100 transition-all duration-300 hover:scale-105" data-filter="zemin">
            Zemin Kaplama
          </button>
        </div>
      </div>

      <div id="references-grid" class="references-grid">
        <References references={references} />
      </div>
    </div>
  </Section>

  <Section bgColor="white">
    <div class="py-20">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl font-bold text-gray-900 text-center mb-12 animate-on-scroll">
          Başarı Rakamlarımız
        </h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
          <div class="text-center animate-scale" style="transition-delay: 0ms">
            <div class="w-20 h-20 bg-accent-100 rounded-full flex items-center justify-center mx-auto mb-4">
              <span class="text-3xl font-bold text-accent-600">500+</span>
            </div>
            <p class="font-semibold text-gray-900">Tamamlanan Proje</p>
          </div>
          <div class="text-center animate-scale" style="transition-delay: 100ms">
            <div class="w-20 h-20 bg-primary-100 rounded-full flex items-center justify-center mx-auto mb-4">
              <span class="text-3xl font-bold text-primary-600">20+</span>
            </div>
            <p class="font-semibold text-gray-900">Yıllık Tecrübe</p>
          </div>
          <div class="text-center animate-scale" style="transition-delay: 200ms">
            <div class="w-20 h-20 bg-secondary-100 rounded-full flex items-center justify-center mx-auto mb-4">
              <span class="text-3xl font-bold text-secondary-600">100%</span>
            </div>
            <p class="font-semibold text-gray-900">Müşteri Memnuniyeti</p>
          </div>
          <div class="text-center animate-scale" style="transition-delay: 300ms">
            <div class="w-20 h-20 bg-dark-100 rounded-full flex items-center justify-center mx-auto mb-4">
              <span class="text-3xl font-bold text-dark-600">50+</span>
            </div>
            <p class="font-semibold text-gray-900">Uzman Personel</p>
          </div>
        </div>
      </div>
    </div>
  </Section>

  <Section bgColor="gray-600" animate={true} animationType="scale">
    <div class="py-16 text-center">
      <h2 class="text-2xl md:text-3xl font-bold text-white mb-4">
        Sizin de Projeniz Hazır Mı?
      </h2>
      <p class="text-lg text-neutral-100 mb-6 max-w-2xl mx-auto">
        Başarılı projelerimize bir yenisini eklemek için sabırsızlanıyoruz
      </p>
      <a
        href="/iletisim"
        class="inline-block bg-white text-primary-700 px-8 py-3 rounded-lg font-medium hover:bg-gray-100 transition-all duration-300 hover:scale-105"
      >
        Teklif Alın
      </a>
    </div>
  </Section>
</BaseLayout>

<script>
  import { observeScrollAnimations } from '../presentation/utils/animations';

  function initAnimations() {
    observeScrollAnimations('.animate-on-scroll');
    observeScrollAnimations('.animate-fade');
    observeScrollAnimations('.animate-scale');
  }

  document.addEventListener('DOMContentLoaded', initAnimations);
  initAnimations();

  // Simple filter functionality
  const filterBtns = document.querySelectorAll('.filter-btn');
  filterBtns.forEach((btn) => {
    const button = btn as HTMLElement;
    button.addEventListener('click', () => {
      // Remove active class from all buttons
      filterBtns.forEach((b) => {
        const btnElement = b as HTMLElement;
        btnElement.classList.remove('bg-accent-500', 'text-white');
        btnElement.classList.add('bg-white', 'text-gray-700');
      });
      // Add active class to clicked button
      button.classList.remove('bg-white', 'text-gray-700');
      button.classList.add('bg-accent-500', 'text-white');

      const filter = button.dataset.filter;
      // In a real implementation, you would filter the grid here
      console.log('Filter:', filter);
    });
  });
</script>
