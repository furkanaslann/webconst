---
import BaseLayout from '../presentation/layouts/BaseLayout.astro';
import ContactForm from '../presentation/components/blocks/ContactForm';
import Section from '../presentation/components/ui/Section.astro';
---

<BaseLayout
  title="İletişim - Webconst"
  description="Webconst ile iletişime geçin. Projeleriniz hakkında konuşmak için formu doldurun veya doğrudan bize ulaşın."
>
  <Section bgColor="gray">
    <div class="py-20">
      <div class="max-w-4xl mx-auto text-center mb-12">
        <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">
          İletişime Geçin
        </h1>
        <p class="text-xl text-gray-600">
          Projeleriniz hakkında konuşmak veya sorularınız için bize ulaşın
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-12">
        <div>
          <h2 class="text-2xl font-bold text-gray-900 mb-6">
            İletişim Formu
          </h2>
          <ContactForm client:load />
        </div>

        <div>
          <h2 class="text-2xl font-bold text-gray-900 mb-6">
            İletişim Bilgileri
          </h2>

          <div class="bg-white rounded-xl shadow-lg p-6 space-y-6">
            <div class="flex items-start">
              <div class="flex-shrink-0 w-12 h-12 bg-primary-100 rounded-lg flex items-center justify-center mr-4">
                <span class="text-xl">📍</span>
              </div>
              <div>
                <h3 class="font-semibold text-gray-900 mb-1">Adres</h3>
                <p class="text-gray-600">
                  İstanbul, Türkiye
                </p>
              </div>
            </div>

            <div class="flex items-start">
              <div class="flex-shrink-0 w-12 h-12 bg-primary-100 rounded-lg flex items-center justify-center mr-4">
                <span class="text-xl">📧</span>
              </div>
              <div>
                <h3 class="font-semibold text-gray-900 mb-1">E-posta</h3>
                <a href="mailto:info@webconst.com" class="text-primary-600 hover:text-primary-700">
                  info@webconst.com
                </a>
              </div>
            </div>

            <div class="flex items-start">
              <div class="flex-shrink-0 w-12 h-12 bg-primary-100 rounded-lg flex items-center justify-center mr-4">
                <span class="text-xl">📞</span>
              </div>
              <div>
                <h3 class="font-semibold text-gray-900 mb-1">Telefon</h3>
                <a href="tel:+902121234567" class="text-primary-600 hover:text-primary-700">
                  +90 212 123 45 67
                </a>
              </div>
            </div>

            <div class="flex items-start">
              <div class="flex-shrink-0 w-12 h-12 bg-primary-100 rounded-lg flex items-center justify-center mr-4">
                <span class="text-xl">🕐</span>
              </div>
              <div>
                <h3 class="font-semibold text-gray-900 mb-1">Çalışma Saatleri</h3>
                <p class="text-gray-600">
                  Pazartesi - Cuma: 09:00 - 18:00
                </p>
              </div>
            </div>
          </div>

          <div class="mt-6 bg-primary-50 rounded-xl p-6">
            <h3 class="font-semibold text-gray-900 mb-2">
              Projeniz mi var?
            </h3>
            <p class="text-gray-600 text-sm">
              Formu doldurarak veya doğrudan e-posta göndererek projeleriniz hakkında
              detaylı bilgi alabilirsiniz. En kısa sürede size dönüş yapacağız.
            </p>
          </div>
        </div>
      </div>
    </div>
  </Section>
</BaseLayout>
