---
import BaseLayout from '../presentation/layouts/BaseLayout.astro';
import ContactForm from '../presentation/components/blocks/ContactForm';
import Section from '../presentation/components/ui/Section.astro';

const contactInfo = {
  address: 'Mimarsinan OSB 1. Cad. No:4, Melikgazi / Kayseri',
  phone: '+90 532 000 00 00',
  email: 'info@webconst.com.tr',
  workingHours: 'Pazartesi - Cumartesi: 08:00 - 18:00',
};
---

<BaseLayout
  title="İletişim - Webconst"
  description="Webconst ile iletişime geçin. Kayseri merkezli inşaat hizmetlerimiz hakkında bilgi almak ve ücretsiz keşif için formu doldurun."
>
  <Section bgColor="gray">
    <div class="py-20 px-6">
      <div class="max-w-4xl mx-auto text-center mb-12 animate-on-scroll">
        <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">
          İletişime Geçin
        </h1>
        <p class="text-xl text-gray-600">
          Projeleriniz hakkında konuşmak veya ücretsiz keşif talep etmek için bize ulaşın
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-12">
        <div class="animate-slide-left">
          <h2 class="text-2xl font-bold text-gray-900 mb-6">
            İletişim Formu
          </h2>
          <ContactForm client:load />
        </div>

        <div class="animate-slide-right">
          <h2 class="text-2xl font-bold text-gray-900 mb-6">
            İletişim Bilgileri
          </h2>

          <div class="bg-white rounded-xl shadow-lg p-6 space-y-6">
            <div class="flex items-start contact-info-item" style="transition-delay: 0ms">
              <div class="flex-shrink-0 w-12 h-12 bg-accent-100 rounded-lg flex items-center justify-center mr-4">
                <svg class="w-6 h-6 text-accent-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-gray-900 mb-1">Adres</h3>
                <p class="text-gray-600">
                  {contactInfo.address}
                </p>
              </div>
            </div>

            <div class="flex items-start contact-info-item" style="transition-delay: 100ms">
              <div class="flex-shrink-0 w-12 h-12 bg-accent-100 rounded-lg flex items-center justify-center mr-4">
                <svg class="w-6 h-6 text-accent-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-gray-900 mb-1">E-posta</h3>
                <a href={`mailto:${contactInfo.email}`} class="text-accent-600 hover:text-accent-700">
                  {contactInfo.email}
                </a>
              </div>
            </div>

            <div class="flex items-start contact-info-item" style="transition-delay: 200ms">
              <div class="flex-shrink-0 w-12 h-12 bg-accent-100 rounded-lg flex items-center justify-center mr-4">
                <svg class="w-6 h-6 text-accent-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-gray-900 mb-1">Telefon</h3>
                <a href={`tel:${contactInfo.phone.replace(/\s/g, '')}`} class="text-accent-600 hover:text-accent-700">
                  {contactInfo.phone}
                </a>
              </div>
            </div>

            <div class="flex items-start contact-info-item" style="transition-delay: 300ms">
              <div class="flex-shrink-0 w-12 h-12 bg-accent-100 rounded-lg flex items-center justify-center mr-4">
                <svg class="w-6 h-6 text-accent-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-gray-900 mb-1">Çalışma Saatleri</h3>
                <p class="text-gray-600">
                  {contactInfo.workingHours}
                </p>
              </div>
            </div>
          </div>

          <div class="mt-6 bg-accent-50 rounded-xl p-6 info-box animate-scale">
            <h3 class="font-semibold text-gray-900 mb-2">
              Ücretsiz Keşif Hizmeti
            </h3>
            <p class="text-gray-600 text-sm">
              Kayseri ve çevresinde sunduğumuz ücretsiz keşif hizmetimizden yararlanmak için formu doldurun
              veya doğrudan bize ulaşın. Uzman ekibimiz projenizi yerinde inceleyerek size özel teklif hazırlar.
            </p>
          </div>
        </div>
      </div>
    </div>
  </Section>

  <Section bgColor="gray-600">
    <div class="py-16 cta-section">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-2xl md:text-3xl font-bold text-white mb-4">
          Hemen İletişime Geçin
        </h2>
        <p class="text-lg text-neutral-100 mb-6">
          Projeniz için profesyonel çözüm almak için sabırsızlanıyoruz
        </p>
        <a
          href={`tel:${contactInfo.phone.replace(/\s/g, '')}`}
          class="inline-block bg-white text-primary-700 px-8 py-3 rounded-lg font-medium hover:bg-gray-100 transition-all duration-300 hover:scale-105"
        >
          Hemen Ara
        </a>
      </div>
    </div>
  </Section>
</BaseLayout>

<style>
  .contact-info-item {
    opacity: 0;
    transform: translateX(20px);
    transition: opacity 0.5s cubic-bezier(0.16, 1, 0.3, 1),
                transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .contact-info-item.animate-in {
    opacity: 1;
    transform: translateX(0);
  }

  .info-box {
    opacity: 0;
    transform: translateY(15px);
    transition: opacity 0.5s cubic-bezier(0.16, 1, 0.3, 1),
                transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .info-box.animate-in {
    opacity: 1;
    transform: translateY(0);
  }

  .cta-section {
    opacity: 0;
    transform: scale(0.95);
    transition: opacity 0.6s cubic-bezier(0.16, 1, 0.3, 1),
                transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .cta-section.animate-in {
    opacity: 1;
    transform: scale(1);
  }

  @media (prefers-reduced-motion: reduce) {
    .contact-info-item,
    .info-box,
    .cta-section {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
  }
</style>

<script>
  import { observeScrollAnimations } from '../presentation/utils/animations';

  function initAnimations() {
    observeScrollAnimations('.animate-on-scroll');
    observeScrollAnimations('.animate-slide-left');
    observeScrollAnimations('.animate-slide-right');
    observeScrollAnimations('.animate-scale');

    // Contact info items
    const contactItems = document.querySelectorAll('.contact-info-item');
    const contactObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('animate-in');
          contactObserver.unobserve(entry.target);
        }
      });
    }, { threshold: 0.2, rootMargin: '0px 0px -50px 0px' });
    contactItems.forEach(item => contactObserver.observe(item));

    // Info box
    const infoBox = document.querySelector('.info-box');
    if (infoBox) {
      const infoBoxObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('animate-in');
            infoBoxObserver.unobserve(entry.target);
          }
        });
      }, { threshold: 0.2, rootMargin: '0px 0px -50px 0px' });
      infoBoxObserver.observe(infoBox);
    }

    // CTA section
    const ctaSection = document.querySelector('.cta-section');
    if (ctaSection) {
      const ctaObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('animate-in');
            ctaObserver.unobserve(entry.target);
          }
        });
      }, { threshold: 0.1 });
      ctaObserver.observe(ctaSection);
    }
  }

  document.addEventListener('DOMContentLoaded', initAnimations);
  initAnimations();
</script>
