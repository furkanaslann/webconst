---
import BaseLayout from '../presentation/layouts/BaseLayout.astro';
import HeroSection from '../presentation/components/blocks/HeroSection.astro';
import ServiceCard from '../presentation/components/blocks/ServiceCard.astro';
import Section from '../presentation/components/ui/Section.astro';
import { services } from '../core/domain/types/service.types';
---

<BaseLayout
  title="Webconst - Profesyonel Web Çözümleri"
  description="Webconst ile dijital dünyada yerinizi alın. Profesyonel web geliştirme ve danışmanlık hizmetleri."
>
  <HeroSection />

  <Section bgColor="gray">
    <div class="py-20">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
          Hizmetlerimiz
        </h2>
        <p class="text-xl text-gray-600 max-w-2xl mx-auto">
          İşinizi dijital dünyaya taşımak için ihtiyacınız olan tüm hizmetleri sunuyoruz
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        {services.map((service) => (
          <ServiceCard service={service} />
        ))}
      </div>
    </div>
  </Section>

  <Section bgColor="white">
    <div class="py-20">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-6">
            Neden Webconst?
          </h2>
          <div class="space-y-4">
            <div class="flex items-start">
              <div class="flex-shrink-0 w-6 h-6 rounded-full bg-primary-100 flex items-center justify-center mr-3 mt-1">
                <svg class="w-4 h-4 text-primary-600" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
              </div>
              <p class="text-gray-600">Modern teknolojiler ile hızlı ve güvenilir çözümler</p>
            </div>
            <div class="flex items-start">
              <div class="flex-shrink-0 w-6 h-6 rounded-full bg-primary-100 flex items-center justify-center mr-3 mt-1">
                <svg class="w-4 h-4 text-primary-600" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
              </div>
              <p class="text-gray-600">SEO uyumlu, yüksek performanslı web siteleri</p>
            </div>
            <div class="flex items-start">
              <div class="flex-shrink-0 w-6 h-6 rounded-full bg-primary-100 flex items-center justify-center mr-3 mt-1">
                <svg class="w-4 h-4 text-primary-600" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
              </div>
              <p class="text-gray-600">Mobil uyumlu ve erişilebilir tasarımlar</p>
            </div>
            <div class="flex items-start">
              <div class="flex-shrink-0 w-6 h-6 rounded-full bg-primary-100 flex items-center justify-center mr-3 mt-1">
                <svg class="w-4 h-4 text-primary-600" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
              </div>
              <p class="text-gray-600">7/24 teknik destek ve bakım hizmetleri</p>
            </div>
          </div>
        </div>

        <div class="relative">
          <div class="aspect-square bg-gradient-to-br from-primary-100 to-primary-200 rounded-2xl flex items-center justify-center">
            <span class="text-9xl">🚀</span>
          </div>
        </div>
      </div>
    </div>
  </Section>

  <Section bgColor="primary">
    <div class="py-20 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">
        Projeye Başlayalım
      </h2>
      <p class="text-xl text-primary-100 mb-8 max-w-2xl mx-auto">
        Fikrinizi hayata geçirmek için hazır mısınız?
      </p>
      <a
        href="/iletisim"
        class="inline-block bg-white text-primary-600 px-8 py-3 rounded-lg font-medium hover:bg-gray-100 transition-colors"
      >
        İletişime Geç
      </a>
    </div>
  </Section>
</BaseLayout>
