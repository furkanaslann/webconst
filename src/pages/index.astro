---
import BaseLayout from '../presentation/layouts/BaseLayout.astro';
import HeroSection from '../presentation/components/blocks/HeroSection.astro';
import ServiceCard from '../presentation/components/blocks/ServiceCard.astro';
import Section from '../presentation/components/ui/Section.astro';
import { services } from '../core/constants/services';
---

<BaseLayout
  title="Webconst - İnşaat Sektöründe Profesyonel Çözümler"
  description="Webconst ile güçlendirme, su yalıtım, zemin kaplama ve yapı kimyasalları hizmetlerini keşfedin. Kayseri merkezli profesyonel inşaat çözümleri."
>
  <HeroSection />

  <Section bgColor="gray">
    <div class="py-20 px-4">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
          Hizmetlerimiz
        </h2>
        <p class="text-xl text-gray-600 max-w-2xl mx-auto">
          Yapı sektöründe ihtiyacınız olan tüm profesyonel hizmetleri sunuyoruz
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
        {services.map((service) => (
          <ServiceCard service={service} />
        ))}
      </div>
    </div>
  </Section>

  <Section bgColor="white">
    <div class="py-20 px-6">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-6">
            Neden Webconst?
          </h2>
          <div class="space-y-4">
            <div class="flex items-start">
              <div class="flex-shrink-0 w-6 h-6 rounded-full bg-accent-100 flex items-center justify-center mr-3 mt-1">
                <svg class="w-4 h-4 text-accent-600" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
              </div>
              <p class="text-gray-600">20+ yıllık sektör tecrübesi</p>
            </div>
            <div class="flex items-start">
              <div class="flex-shrink-0 w-6 h-6 rounded-full bg-accent-100 flex items-center justify-center mr-3 mt-1">
                <svg class="w-4 h-4 text-accent-600" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
              </div>
              <p class="text-gray-600">Uzman inşaat mühendisleri kadrosu</p>
            </div>
            <div class="flex items-start">
              <div class="flex-shrink-0 w-6 h-6 rounded-full bg-accent-100 flex items-center justify-center mr-3 mt-1">
                <svg class="w-4 h-4 text-accent-600" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
              </div>
              <p class="text-gray-600">Deprem yönetmeliğine uygun projeler</p>
            </div>
            <div class="flex items-start">
              <div class="flex-shrink-0 w-6 h-6 rounded-full bg-accent-100 flex items-center justify-center mr-3 mt-1">
                <svg class="w-4 h-4 text-accent-600" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
              </div>
              <p class="text-gray-600">Kaliteli malzeme ve işçilik garantisi</p>
            </div>
            <div class="flex items-start">
              <div class="flex-shrink-0 w-6 h-6 rounded-full bg-accent-100 flex items-center justify-center mr-3 mt-1">
                <svg class="w-4 h-4 text-accent-600" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
              </div>
              <p class="text-gray-600">Zamanında proje teslimatı</p>
            </div>
          </div>
        </div>

        <div class="relative">
          <div class="aspect-square bg-gradient-to-br from-secondary-100 via-neutral-100 to-accent-100 rounded-2xl flex items-center justify-center">
            <div class="text-center p-8">
              <div class="grid grid-cols-2 gap-6">
                <div class="bg-white/80 rounded-xl p-4 shadow-md">
                  <p class="text-3xl font-bold text-accent-600">500+</p>
                  <p class="text-sm text-gray-600">Tamamlanan Proje</p>
                </div>
                <div class="bg-white/80 rounded-xl p-4 shadow-md">
                  <p class="text-3xl font-bold text-accent-600">20+</p>
                  <p class="text-sm text-gray-600">Yıllık Tecrübe</p>
                </div>
                <div class="bg-white/80 rounded-xl p-4 shadow-md">
                  <p class="text-3xl font-bold text-accent-600">%100</p>
                  <p class="text-sm text-gray-600">Müşteri Memnuniyeti</p>
                </div>
                <div class="bg-white/80 rounded-xl p-4 shadow-md">
                  <p class="text-3xl font-bold text-accent-600">50+</p>
                  <p class="text-sm text-gray-600">Uzman Personel</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </Section>

  <Section bgColor="gray-600">
    <div class="py-20 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">
        Projeniz İçin Teklif Alın
      </h2>
      <p class="text-xl text-neutral-100 mb-8 max-w-2xl mx-auto">
        Güçlendirme, yalıtım veya zemin kaplama projeleriniz için ücretsiz keşif ve teklif hizmetimizden yararlanın
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/iletisim"
          class="inline-block bg-accent-500 text-white px-8 py-4 rounded-lg font-medium hover:bg-accent-600 transition-colors shadow-lg"
        >
          Teklif Al
        </a>
        <a
          href="/referanslar"
          class="inline-block bg-white/10 text-white border-2 border-white/30 px-8 py-4 rounded-lg font-medium hover:bg-white/20 transition-colors"
        >
          Referanslarımız
        </a>
      </div>
    </div>
  </Section>
</BaseLayout>
