---
import BaseLayout from '../presentation/layouts/BaseLayout.astro';
import Section from '../presentation/components/ui/Section.astro';
import { services } from '../core/constants/services';
---

<BaseLayout
  title="Hizmetler - Webconst"
  description="Webconst'in sunduğu profesyonel güçlendirme, su yalıtım, zemin kaplama ve yapı kimyasalları hizmetlerini keşfedin."
>
  <Section bgColor="gray">
    <div class="py-20 px-6">
      <div class="text-center mb-16">
        <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">
          Hizmetlerimiz
        </h1>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          Yapı sektöründe 20+ yıllık tecrübemizle kaliteli ve güvenilir hizmetler sunuyoruz.
          Her projede müşteri memnuniyetini ve kaliteyi ön planda tutuyoruz.
        </p>
      </div>

      <div class="space-y-24">
        {services.map((service, index) => (
          <div id={service.slug} class="scroll-mt-24">
            <div class={`grid md:grid-cols-2 gap-12 items-center ${index % 2 === 1 ? 'md:flex-row-reverse' : ''}`}>
              <div class={index % 2 === 1 ? 'md:order-2' : ''}>
                <div class="aspect-square rounded-2xl overflow-hidden bg-neutral-100">
                  <img
                    src={service.image}
                    alt={service.title}
                    class="w-full h-full object-cover"
                  />
                </div>
              </div>

              <div class={index % 2 === 1 ? 'md:order-1' : ''}>
                <h2 class="text-3xl font-bold text-gray-900 mb-4">
                  {service.title}
                </h2>
                <p class="text-lg text-gray-600 mb-6">
                  {service.description}
                </p>

                <h3 class="text-lg font-semibold text-gray-900 mb-4">Hizmet Detayları:</h3>
                <ul class="space-y-3 text-gray-600">
                  {service.features.map((feature) => (
                    <li class="flex items-center">
                      <svg class="w-5 h-5 text-accent-500 mr-3 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                      </svg>
                      {feature}
                    </li>
                  ))}
                </ul>

                <a
                  href="/iletisim"
                  class="inline-block mt-6 bg-accent-500 text-white px-6 py-3 rounded-lg font-medium hover:bg-accent-600 transition-colors"
                >
                  Teklif Al
                </a>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </Section>

  <Section bgColor="gray-600">
    <div class="py-16 text-center">
      <h2 class="text-2xl md:text-3xl font-bold text-white mb-4">
        Projeniz İçin Profesyonel Çözüm
      </h2>
      <p class="text-lg text-neutral-100 mb-6 max-w-2xl mx-auto">
        Hizmetlerimiz hakkında detaylı bilgi almak ve ücretsiz keşif için bizimle iletişime geçin
      </p>
      <a
        href="/iletisim"
        class="inline-block bg-white text-primary-700 px-8 py-3 rounded-lg font-medium hover:bg-gray-100 transition-colors"
      >
        İletişime Geç
      </a>
    </div>
  </Section>
</BaseLayout>
