---
import BaseLayout from '../presentation/layouts/BaseLayout.astro';
import Section from '../presentation/components/ui/Section.astro';
import { services } from '../core/constants/services';
---

<BaseLayout
  title="Hizmetler - Webconst"
  description="Webconst'in sunduğu profesyonel güçlendirme, su yalıtım, zemin kaplama ve yapı kimyasalları hizmetlerini keşfedin."
>
  <Section bgColor="gray">
    <div class="py-20 px-6">
      <div class="text-center mb-16">
        <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">
          Hizmetlerimiz
        </h1>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          Yapı sektöründe 20+ yıllık tecrübemizle kaliteli ve güvenilir hizmetler sunuyoruz.
          Her projede müşteri memnuniyetini ve kaliteyi ön planda tutuyoruz.
        </p>
      </div>

      <div class="space-y-24">
        {services.map((service, index) => (
          <div id={service.slug} class="scroll-mt-24">
            <div class={`grid md:grid-cols-2 gap-12 items-center ${index % 2 === 1 ? 'md:flex-row-reverse' : ''}`}>
              <div class={index % 2 === 1 ? 'md:order-2' : ''}>
                <div class="aspect-square bg-gradient-to-br from-secondary-100 via-neutral-100 to-accent-100 rounded-2xl flex items-center justify-center">
                  <div class="text-center p-8">
                    {service.icon === 'building' && (
                      <svg class="w-32 h-32 text-primary-500 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
                      </svg>
                    )}
                    {service.icon === 'water' && (
                      <svg class="w-32 h-32 text-primary-500 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path>
                      </svg>
                    )}
                    {service.icon === 'flooring' && (
                      <svg class="w-32 h-32 text-primary-500 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"></path>
                      </svg>
                    )}
                    {service.icon === 'chemical' && (
                      <svg class="w-32 h-32 text-primary-500 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path>
                      </svg>
                    )}
                  </div>
                </div>
              </div>

              <div class={index % 2 === 1 ? 'md:order-1' : ''}>
                <h2 class="text-3xl font-bold text-gray-900 mb-4">
                  {service.title}
                </h2>
                <p class="text-lg text-gray-600 mb-6">
                  {service.description}
                </p>

                <h3 class="text-lg font-semibold text-gray-900 mb-4">Hizmet Detayları:</h3>
                <ul class="space-y-3 text-gray-600">
                  {service.features.map((feature) => (
                    <li class="flex items-center">
                      <svg class="w-5 h-5 text-accent-500 mr-3 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                      </svg>
                      {feature}
                    </li>
                  ))}
                </ul>

                <a
                  href="/iletisim"
                  class="inline-block mt-6 bg-accent-500 text-white px-6 py-3 rounded-lg font-medium hover:bg-accent-600 transition-colors"
                >
                  Teklif Al
                </a>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </Section>

  <Section bgColor="gray-600">
    <div class="py-16 text-center">
      <h2 class="text-2xl md:text-3xl font-bold text-white mb-4">
        Projeniz İçin Profesyonel Çözüm
      </h2>
      <p class="text-lg text-neutral-100 mb-6 max-w-2xl mx-auto">
        Hizmetlerimiz hakkında detaylı bilgi almak ve ücretsiz keşif için bizimle iletişime geçin
      </p>
      <a
        href="/iletisim"
        class="inline-block bg-white text-primary-700 px-8 py-3 rounded-lg font-medium hover:bg-gray-100 transition-colors"
      >
        İletişime Geç
      </a>
    </div>
  </Section>
</BaseLayout>
