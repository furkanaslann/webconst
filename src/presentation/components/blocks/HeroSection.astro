---
import Section from '../ui/Section.astro';
import { Swiper, SwiperWrapper, SwiperSlide, SwiperPagination, SwiperButtonPrev, SwiperButtonNext } from 'astro-swiper';
import { heroSlides } from '../../../core/constants/heroSlides';

interface Props {
  title?: string;
  subtitle?: string;
  ctaText?: string;
  ctaLink?: string;
  cta2Text?: string;
  cta2Link?: string;
  bgImage?: boolean;
  enableSlider?: boolean;
  autoplayDelay?: number;
  showPagination?: boolean;
  showNavigation?: boolean;
}

const {
  title = 'Yapı Sektöründe Güvenilir Çözümler',
  subtitle = 'Güçlendirme, su yalıtım, zemin kaplama ve yapı kimyasalları alanında profesyonel hizmetler',
  ctaText = 'Teklif Al',
  ctaLink = '/iletisim',
  cta2Text = 'Hizmetlerimiz',
  cta2Link = '/hizmetler',
  bgImage = true,
  enableSlider = false,
  autoplayDelay = 5000,
  showPagination = true,
  showNavigation = true,
} = Astro.props;
---

<Section className="py-20 md:py-32">
  <div class="container mx-auto px-4 text-center">
    <div class="max-w-4xl mx-auto">
      <h1 class="text-4xl md:text-6xl font-bold text-gray-900 mb-6 leading-tight">
        {title}
      </h1>
      <p class="text-xl text-gray-600 mb-10 max-w-2xl mx-auto">
        {subtitle}
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href={ctaLink}
          class="inline-block bg-accent-500 text-white px-8 py-4 rounded-lg font-medium hover:bg-accent-600 transition-colors shadow-lg"
        >
          {ctaText}
        </a>
        <a
          href={cta2Link}
          class="inline-block bg-white text-primary-700 px-8 py-4 rounded-lg font-medium hover:bg-gray-50 transition-colors border-2 border-primary-200"
        >
          {cta2Text}
        </a>
      </div>
    </div>

    {bgImage && !enableSlider && (
      <div class="mt-16 relative">
        <div class="aspect-video bg-gradient-to-br from-secondary-100 via-neutral-100 to-accent-100 rounded-2xl flex items-center justify-center overflow-hidden">
          <div class="text-center p-8">
            <svg class="w-32 h-32 text-primary-400 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
            </svg>
            <p class="text-primary-600 font-medium">20+ Yıllık Tecrübe</p>
            <p class="text-gray-500 mt-2">Kayseri ve çevresinde profesyonel hizmet</p>
          </div>
        </div>
      </div>
    )}

    {bgImage && enableSlider && (
      <div class="mt-16 relative">
        <Swiper
          options={{
            loop: true,
            autoplay: {
              delay: autoplayDelay,
              disableOnInteraction: false,
              pauseOnMouseEnter: true,
            },
            pagination: showPagination ? {
              el: '.swiper-pagination',
              clickable: true,
            } : undefined,
            navigation: showNavigation ? {
              nextEl: '.swiper-button-next',
              prevEl: '.swiper-button-prev',
            } : undefined,
            effect: 'fade',
            fadeEffect: {
              crossFade: true,
            },
            speed: 800,
          }}
          class="hero-swiper"
        >
          <SwiperWrapper>
            {heroSlides.map((slide) => (
              <SwiperSlide>
                <div class="aspect-video bg-gradient-to-br from-secondary-100 via-neutral-100 to-accent-100 rounded-2xl flex items-center justify-center overflow-hidden relative">
                  <!-- Background Görsel -->
                  <img
                    src={slide.image}
                    alt={slide.title}
                    class="absolute inset-0 w-full h-full object-cover"
                    loading="lazy"
                  />
                  <!-- Gradient Overlay -->
                  <div class="absolute inset-0 bg-gradient-to-br from-secondary-100/10 via-neutral-100/20 to-accent-100/10"></div>
                  <!-- Üzerinde Kart İçeriği -->
                  <div class="hero-slide-card absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 text-center p-8 bg-white/50 backdrop-blur-md rounded-2xl shadow-xl max-w-lg">
                    <h3 class="hero-slide-title text-2xl md:text-3xl font-bold text-gray-900 mb-3">{slide.title}</h3>
                    <p class="hero-slide-description text-gray-600 text-sm leading-relaxed">{slide.description}</p>
                  </div>
                </div>
              </SwiperSlide>
            ))}
          </SwiperWrapper>

          {showPagination && <SwiperPagination class="!bottom-4" />}
          {showNavigation && (
            <>
              <SwiperButtonPrev class="!text-white" />
              <SwiperButtonNext class="!text-white" />
            </>
          )}
        </Swiper>
      </div>
    )}
  </div>
</Section>

<style>
  :global(.hero-swiper .swiper-pagination-bullet) {
    background: rgba(255, 255, 255, 0.5);
    opacity: 1;
  }
  :global(.hero-swiper .swiper-pagination-bullet-active) {
    background: white;
  }

  /* Slide Card Animations */
  .hero-slide-card {
    opacity: 0;
    transform: translate(-50%, -40%);
  }

  .hero-slide-card.animate {
    animation: slideCardFadeIn 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes slideCardFadeIn {
    to {
      opacity: 1;
      transform: translate(-50%, -50%);
    }
  }

  .hero-slide-title {
    opacity: 0;
    transform: translateY(15px);
  }

  .hero-slide-card.animate .hero-slide-title {
    animation: slideTitleFadeIn 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.15s forwards;
  }

  @keyframes slideTitleFadeIn {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .hero-slide-description {
    opacity: 0;
    transform: translateY(15px);
  }

  .hero-slide-card.animate .hero-slide-description {
    animation: slideDescFadeIn 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.3s forwards;
  }

  @keyframes slideDescFadeIn {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

<script>
  function initSlideAnimations() {
    const swiper = document.querySelector('.hero-swiper');
    if (!swiper) return;

    const animateActiveSlide = () => {
      // Remove animation from all cards
      swiper.querySelectorAll('.hero-slide-card').forEach((card) => {
        card.classList.remove('animate');
      });

      // Add animation to active slide card
      const activeCard = swiper.querySelector('.swiper-slide-active .hero-slide-card');
      if (activeCard) {
        // Force reflow to restart animation
        void activeCard.offsetWidth;
        activeCard.classList.add('animate');
      }
    };

    // Initial animation
    setTimeout(animateActiveSlide, 100);

    // Watch for slide changes
    const observer = new MutationObserver(() => {
      animateActiveSlide();
    });

    // Observe slide class changes
    swiper.querySelectorAll('.swiper-slide').forEach((slide) => {
      observer.observe(slide, { attributes: true, attributeFilter: ['class'] });
    });
  }

  // Initialize when DOM is ready
  document.addEventListener('DOMContentLoaded', initSlideAnimations);
  // Fallback for Astro's page load
  initSlideAnimations();
</script>
