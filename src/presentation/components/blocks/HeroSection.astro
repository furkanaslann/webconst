---
import Section from '../ui/Section.astro';

interface Props {
  title?: string;
  subtitle?: string;
  ctaText?: string;
  ctaLink?: string;
  bgImage?: boolean;
}

const {
  title = 'Yapı Sektöründe Güvenilir Çözümler',
  subtitle = 'Güçlendirme, su yalıtım, zemin kaplama ve yapı kimyasalları konusunda profesyonel hizmetler',
  ctaText = 'Teklif Al',
  ctaLink = '/iletisim',
  bgImage = true,
} = Astro.props;
---

<Section className="py-20 md:py-32">
  <div class="container mx-auto px-4 text-center">
    <div class="max-w-4xl mx-auto">
      <h1 class="text-4xl md:text-6xl font-bold text-gray-900 mb-6 leading-tight">
        {title}
      </h1>
      <p class="text-xl text-gray-600 mb-10 max-w-2xl mx-auto">
        {subtitle}
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href={ctaLink}
          class="inline-block bg-accent-500 text-white px-8 py-4 rounded-lg font-medium hover:bg-accent-600 transition-colors shadow-lg"
        >
          {ctaText}
        </a>
        <a
          href="/hizmetler"
          class="inline-block bg-white text-primary-700 px-8 py-4 rounded-lg font-medium hover:bg-gray-50 transition-colors border-2 border-primary-200"
        >
          Hizmetlerimiz
        </a>
      </div>
    </div>

    {bgImage && (
      <div class="mt-16 relative">
        <div class="aspect-video bg-gradient-to-br from-secondary-100 via-neutral-100 to-accent-100 rounded-2xl flex items-center justify-center overflow-hidden">
          <div class="text-center p-8">
            <svg class="w-32 h-32 text-primary-400 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
            </svg>
            <p class="text-primary-600 font-medium">20+ Yıllık Tecrübe</p>
            <p class="text-gray-500 mt-2">Kayseri ve çevresinde profesyonel hizmet</p>
          </div>
        </div>
      </div>
    )}
  </div>
</Section>
