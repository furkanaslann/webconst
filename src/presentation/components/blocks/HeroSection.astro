---
import Section from '../ui/Section.astro';

interface Props {
  title?: string;
  subtitle?: string;
  ctaText?: string;
  ctaLink?: string;
}

const {
  title = 'Webconst - Dijital Çözümler',
  subtitle = 'Modern web teknolojileri ile işinizi dijital dünyaya taşıyın',
  ctaText = 'İletişime Geç',
  ctaLink = '/iletisim',
} = Astro.props;
---

<Section class="py-20">
  <div class="container mx-auto px-4 text-center">
    <h1 class="text-4xl md:text-6xl font-bold text-gray-900 mb-6">
      {title}
    </h1>
    <p class="text-xl text-gray-600 mb-8 max-w-2xl mx-auto">
      {subtitle}
    </p>
    <a
      href={ctaLink}
      class="inline-block bg-primary-600 text-white px-8 py-3 rounded-lg font-medium hover:bg-primary-700 transition-colors"
    >
      {ctaText}
    </a>
  </div>
</Section>
