---
interface Props {
  className?: string;
  bgColor?: 'white' | 'gray' | 'gray-600' | 'primary';
  animate?: boolean;
  animationType?: 'fade' | 'slide' | 'scale';
}

const {
  className = '',
  bgColor = 'white',
  animate = false,
  animationType = 'fade',
} = Astro.props;

const bgClasses = {
  white: 'bg-white',
  gray: 'bg-gray-50',
  'gray-600': 'bg-gray-600',
  primary: 'bg-primary-50',
};

const animationClasses = animate ? {
  fade: 'animate-fade',
  slide: 'animate-on-scroll',
  scale: 'animate-scale',
}[animationType] || '' : '';
---

<section class={`${bgClasses[bgColor]} ${className} ${animationClasses}`}>
  <slot />
</section>
